{
  "name": "xmemo-vscode",
  "displayName": "XMemo — Cross-Agent Cloud Memory",
  "description": "User-owned, identity-aware cloud memory for your editor. Recall project context, save decisions, and share memory across Cursor, Claude, Codex, and your CLI.",
  "version": "0.1.0",
  "publisher": "xmemo",
  "license": "MIT",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.101.0"
  },
  "categories": [
    "AI",
    "Machine Learning",
    "Other"
  ],
  "keywords": [
    "xmemo",
    "memory",
    "mcp",
    "agent-memory",
    "cursor",
    "developer-tools",
    "oauth"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yonro/memory-os-cli.git",
    "directory": "extensions/vscode"
  },
  "homepage": "https://xmemo.dev/product/mcp",
  "bugs": {
    "url": "https://github.com/yonro/memory-os-cli/issues"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "authentication": [
      {
        "id": "xmemo",
        "label": "XMemo"
      }
    ],
    "mcpServerDefinitionProviders": [
      {
        "id": "xmemo.mcp",
        "label": "XMemo"
      }
    ],
    "languageModelTools": [
      {
        "id": "xmemo_recall",
        "name": "xmemo_recall",
        "toolReferenceName": "xmemo_recall",
        "displayName": "Recall XMemo memory",
        "modelDescription": "Retrieve the most relevant XMemo memory for the current task or question.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "query": { "type": "string", "description": "A concise natural-language query describing what you are trying to recall." },
            "limit": { "type": "number", "description": "Maximum number of memories to return.", "default": 3 }
          },
          "required": ["query"]
        },
        "canBeReferencedInPrompt": true,
        "tags": ["xmemo", "memory"]
      },
      {
        "id": "xmemo_search_memory",
        "name": "xmemo_search_memory",
        "toolReferenceName": "xmemo_search_memory",
        "displayName": "Search XMemo memory",
        "modelDescription": "Search XMemo memories with filters and return compact, cited snippets.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "query": { "type": "string", "description": "Search query." },
            "limit": { "type": "number", "description": "Maximum number of results.", "default": 5 }
          },
          "required": ["query"]
        },
        "canBeReferencedInPrompt": true,
        "tags": ["xmemo", "memory"]
      },
      {
        "id": "xmemo_context_pack",
        "name": "xmemo_context_pack",
        "toolReferenceName": "xmemo_context_pack",
        "displayName": "Build XMemo context pack",
        "modelDescription": "Build a task-scoped context pack from XMemo memory plus current workspace hints.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "task": { "type": "string", "description": "A one-sentence description of the task." },
            "limit": { "type": "number", "description": "Maximum number of memory entries.", "default": 5 }
          },
          "required": ["task"]
        },
        "canBeReferencedInPrompt": true,
        "tags": ["xmemo", "memory"]
      },
      {
        "id": "xmemo_remember",
        "name": "xmemo_remember",
        "toolReferenceName": "xmemo_remember",
        "displayName": "Remember in XMemo",
        "modelDescription": "Save an explicit user-approved decision, fact, or context into XMemo.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "content": { "type": "string", "description": "The exact content to remember." },
            "path": { "type": "string", "description": "A file path or location to associate with the memory.", "default": "" }
          },
          "required": ["content"]
        },
        "canBeReferencedInPrompt": true,
        "tags": ["xmemo", "memory"]
      },
      {
        "id": "xmemo_explain_memory",
        "name": "xmemo_explain_memory",
        "toolReferenceName": "xmemo_explain_memory",
        "displayName": "Explain XMemo memory",
        "modelDescription": "Explain why a memory matched or exists in XMemo.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "reference": { "type": "string", "description": "A memory ID, path, or query identifying the memory." }
          },
          "required": ["reference"]
        },
        "canBeReferencedInPrompt": true,
        "tags": ["xmemo", "memory"]
      }
    ],
    "chatParticipants": [
      {
        "id": "xmemo",
        "name": "xmemo",
        "description": "XMemo agent memory: status, recall, remember, and agent integrations.",
        "isSticky": true,
        "commands": [
          { "name": "status", "description": "Show XMemo sign-in, MCP, and integration state" },
          { "name": "recall", "description": "Recall relevant XMemo memories" },
          { "name": "remember", "description": "Save a memory to XMemo" },
          { "name": "explain", "description": "Explain why a memory matched" },
          { "name": "agents", "description": "Open the Agent Integrations panel" }
        ]
      }
    ],
    "commands": [
      {
        "command": "xmemo.signIn",
        "title": "XMemo: Sign In"
      },
      {
        "command": "xmemo.signOut",
        "title": "XMemo: Sign Out"
      },
      {
        "command": "xmemo.remember",
        "title": "XMemo: Remember…"
      },
      {
        "command": "xmemo.recall",
        "title": "XMemo: Recall…"
      },
      {
        "command": "xmemo.searchMemory",
        "title": "XMemo: Search Memory"
      },
      {
        "command": "xmemo.saveSelection",
        "title": "XMemo: Save Selection as Memory"
      },
      {
        "command": "xmemo.refreshMemories",
        "title": "XMemo: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "xmemo.showAgentIntegrations",
        "title": "XMemo: Show Agent Integrations"
      },
      {
        "command": "xmemo.refreshAgentIntegrations",
        "title": "XMemo: Refresh Agent Integrations",
        "icon": "$(refresh)"
      },
      {
        "command": "xmemo.connectAgent",
        "title": "XMemo: Connect Agent"
      },
      {
        "command": "xmemo.disconnectAgent",
        "title": "XMemo: Disconnect Agent"
      },
      {
        "command": "xmemo.connectAllAgents",
        "title": "XMemo: Connect All Detected Agents"
      },
      {
        "command": "xmemo.openAgentConfig",
        "title": "XMemo: Open Agent Config"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "xmemo.saveSelection",
          "when": "editorHasSelection",
          "group": "9_xmemo"
        }
      ],
      "view/title": [
        {
          "command": "xmemo.refreshMemories",
          "when": "view == xmemo.memories",
          "group": "navigation"
        },
        {
          "command": "xmemo.refreshAgentIntegrations",
          "when": "view == xmemo.agentIntegrations",
          "group": "navigation"
        },
        {
          "command": "xmemo.connectAllAgents",
          "when": "view == xmemo.agentIntegrations",
          "group": "navigation@1"
        }
      ],
      "view/item/context": [
        {
          "command": "xmemo.connectAgent",
          "when": "view == xmemo.agentIntegrations && viewItem =~ /agent\\.(config-found|config-missing)/",
          "group": "xmemo@1"
        },
        {
          "command": "xmemo.disconnectAgent",
          "when": "view == xmemo.agentIntegrations && viewItem == agent.connected",
          "group": "xmemo@2"
        },
        {
          "command": "xmemo.openAgentConfig",
          "when": "view == xmemo.agentIntegrations",
          "group": "xmemo@3"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "xmemo",
          "title": "XMemo",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "xmemo": [
        {
          "id": "xmemo.memories",
          "name": "Recent Memories"
        },
        {
          "id": "xmemo.agentIntegrations",
          "name": "Agent Integrations"
        }
      ]
    },
    "configuration": {
      "title": "XMemo",
      "properties": {
        "xmemo.apiBaseUrl": {
          "type": "string",
          "default": "https://xmemo.dev",
          "description": "Base URL of the XMemo service. The MCP endpoint is <baseUrl>/mcp."
        },
        "xmemo.agentId": {
          "type": "string",
          "default": "vscode",
          "description": "Agent ID used for attribution (X-Memory-OS-Agent-ID header)."
        },
        "xmemo.autoCapture": {
          "type": "boolean",
          "default": false,
          "description": "Reserved for v1.1: suggest saving on save/test (opt-in, always confirms). Not yet implemented."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit",
    "vscode:prepublish": "npm run typecheck && node esbuild.mjs --production",
    "package": "npx --yes @vscode/vsce package --no-dependencies",
    "publish:vsce": "npx --yes @vscode/vsce publish --no-dependencies",
    "publish:ovsx": "npx --yes ovsx publish",
    "test": "node ./out-test/runTest.js",
    "pretest": "npm run build && tsc -p ./tsconfig.test.json"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.101.0",
    "esbuild": "^0.25.10",
    "typescript": "^5.6.3",
    "@vscode/test-electron": "^2.4.1",
    "mocha": "^10.7.0",
    "@types/mocha": "^10.0.7",
    "glob": "^11.0.0",
    "@types/glob": "^8.1.0"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5"
  }
}
